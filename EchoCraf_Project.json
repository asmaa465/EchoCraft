        "jsCode": "// helper: extract the text of the selected option for a field\nfunction getSelectedText(field) {\n  const selectedIds = field.value;\n  const options = field.options || [];\n  const selectedOptions = options.filter(opt => selectedIds.includes(opt.id));\n  return selectedOptions.length > 0 ? selectedOptions[0].text : null;\n}\n\n// grab all needed fields\nconst fields = $input.first().json.body.data.fields;\n\nconst field9  = fields[9];\nconst field10 = fields[10];\nconst field11 = fields[11];\nconst field16 = fields[16];\n\n\n// return 4 separate items\nreturn [\n  { json: { Audience:     getSelectedText(field9)  } },\n  { json: { WritingStyle: getSelectedText(field10) } },\n  { json: { Tone:         getSelectedText(field11) } },\n  { json: { Output_in:    getSelectedText(field16) } }\n];\n"
      },
